name_prefix  = "ddc"
environment  = "proposal"
owner        = "platform"

# AWS profile can be null to rely on environment credentials.
aws_profile = "default"

aws_site_a_region = "us-east-1"
aws_site_b_region = "us-west-2"

gcp_project_id       = "your-gcp-project-id"
gcp_credentials_json = null
cloudflare_api_token = "disabled"
gcp_site_c_region    = "us-east4"
gcp_site_d_region    = "us-west1"

site_a_ipv4_cidr = "10.10.0.0/20"
site_b_ipv4_cidr = "10.20.0.0/20"
site_c_ipv4_cidr = "10.30.0.0/20"
site_d_ipv4_cidr = "10.40.0.0/20"

site_a_ipv6_ula = "fdca:fcaf:e000::/56"
site_b_ipv6_ula = "fdca:fcaf:e100::/56"
site_c_ipv6_ula = "fdca:fcaf:e200::/56"
site_d_ipv6_ula = "fdca:fcaf:e300::/56"

gcp_enable_ipv6 = true

aws_site_a_vpn_asn = 64512
aws_site_b_vpn_asn = 64513

phase2_primary_bgp_priority  = 100
phase2_failover_bgp_priority = 200

phase2_gcp_router_asns = {
  ac = 65010
  ad = 65011
  bc = 65020
  bd = 65021
}

# Set a unique secret seed before production use.
phase2_secret_seed = "replace-this-phase2-seed"
phase2_enable_intercloud = true

# Set true to deploy EKS/GKE control planes in all four sites.
phase3_enable_platform = false

# Optional EKS version (example: "1.31"). Null lets AWS choose.
phase3_aws_eks_cluster_version = null
phase3_aws_enabled_cluster_log_types = ["api", "audit", "authenticator"]
phase3_aws_endpoint_public_access    = true
phase3_aws_endpoint_private_access   = true
phase3_aws_public_access_cidrs       = ["203.0.113.10/32"]

phase3_gcp_release_channel     = "REGULAR"
phase3_gcp_deletion_protection = false
phase3_gcp_master_authorized_networks = [
  {
    cidr_block   = "203.0.113.10/32"
    display_name = "operator-workstation"
  }
]

# Optional per-site Pod/Service CIDR overrides for GKE.
phase3_site_c_cluster_ipv4_cidr_block  = null
phase3_site_c_services_ipv4_cidr_block = null
phase3_site_d_cluster_ipv4_cidr_block  = null
phase3_site_d_services_ipv4_cidr_block = null

# Phase 4 service onboarding (worker capacity).
phase4_enable_service_onboarding = false

phase4_aws_node_desired_size      = 1
phase4_aws_node_min_size          = 1
phase4_aws_node_max_size          = 2
phase4_aws_node_instance_types    = ["t3.small"]
phase4_aws_node_capacity_type     = "ON_DEMAND"
phase4_aws_node_disk_size         = 80
phase4_aws_node_ami_type          = null
phase4_aws_node_labels            = {}
phase4_aws_node_taints            = []
phase4_aws_node_max_unavailable   = 1
phase4_aws_enable_ssm_managed_instance_core = false
phase4_aws_enable_private_service_endpoints = true

phase4_gcp_node_machine_type       = "e2-standard-4"
phase4_gcp_node_disk_size_gb       = 100
phase4_gcp_node_disk_type          = "pd-standard"
phase4_gcp_node_image_type         = "COS_CONTAINERD"
phase4_gcp_node_spot               = false
phase4_gcp_node_enable_autoscaling = true
phase4_gcp_node_min_count          = 1
phase4_gcp_node_max_count          = 2
phase4_gcp_node_initial_count      = 1
phase4_gcp_node_service_account    = null
phase4_gcp_node_labels             = {}
phase4_gcp_node_tags               = []
phase4_gcp_node_oauth_scopes = [
  "https://www.googleapis.com/auth/logging.write",
  "https://www.googleapis.com/auth/monitoring",
  "https://www.googleapis.com/auth/devstorage.read_only"
]
phase4_gcp_node_disable_legacy_metadata_endpoints = true
phase4_gcp_node_enable_secure_boot                = true
phase4_gcp_node_enable_integrity_monitoring       = true
phase4_gcp_node_workload_metadata_mode            = "GCE_METADATA"

# Source-material Phase 4 deliverable tracking flags.
phase4_enable_published_app_path  = false
phase4_enable_published_app_tls   = false
phase4_aws_enable_ingress_internet_edge = false
phase4_enable_cloudflare_edge     = false
phase4_enable_vdi_reference_stack = false

# Optional Cloudflare edge layer for published app endpoints.
# Set cloudflare_api_token to a real token (or pass via scripts/env) when enabling this layer.
phase4_cloudflare_zone_id            = null
phase4_cloudflare_zone_name          = null
phase4_cloudflare_site_a_record_name = null
phase4_cloudflare_site_b_record_name = null
phase4_cloudflare_additional_records = {}
phase4_cloudflare_record_proxied     = false
phase4_cloudflare_record_ttl         = 300

# Optional published app path baseline (AWS Site A/B).
phase4_published_app_listener_port = 80
phase4_published_app_https_port    = 443
phase4_published_app_tls_ssl_policy = "ELBSecurityPolicy-TLS13-1-2-2021-06"
phase4_site_a_published_app_tls_subject_alternative_names = []
phase4_site_b_published_app_tls_subject_alternative_names = []
phase4_published_app_allowed_ingress_ipv4_cidrs = ["0.0.0.0/0"]
phase4_published_app_allowed_ingress_ipv6_cidrs = ["::/0"]
phase4_published_app_health_check_path           = "/healthz"
phase4_published_app_root_redirect_path          = "/guacamole/"
phase4_published_app_backend_port                = 80
phase4_published_app_waf_rate_limit              = 2000

# Register backend targets only when workloads are reachable from ingress subnets.
phase4_site_a_published_app_backend_ipv4_targets = []
phase4_site_b_published_app_backend_ipv4_targets = []

# Optional VDI reference stack baseline (AWS + GCP Site A/B/C/D).
phase4_vdi_aws_desktop_controlled_egress_ipv4_cidrs = ["0.0.0.0/0"]
phase4_vdi_aws_desktop_controlled_egress_ipv6_cidrs = ["::/0"]
phase4_vdi_identity_ssm_parameter_arn_patterns      = ["arn:aws:ssm:*:*:parameter/ddc/vdi/*"]
phase4_vdi_identity_secret_arn_patterns             = ["arn:aws:secretsmanager:*:*:secret:ddc-vdi-*"]
phase4_vdi_aws_node_desired_size                    = 1
phase4_vdi_aws_node_min_size                        = 1
phase4_vdi_aws_node_max_size                        = 2
phase4_vdi_aws_node_instance_types                  = ["t3.small"]
phase4_vdi_aws_node_labels                          = {}
phase4_vdi_aws_node_taints = [
  {
    key    = "workload"
    value  = "vdi"
    effect = "NO_SCHEDULE"
  }
]
phase4_vdi_aws_node_max_unavailable = 1
phase4_vdi_enable_aws_worker_pools  = true

phase4_vdi_gcp_desktop_controlled_egress_ipv4_cidrs = ["0.0.0.0/0"]
phase4_vdi_gcp_manage_broker_identity               = true
phase4_vdi_enable_gcp_worker_pools                  = true
phase4_vdi_gcp_node_machine_type                     = "e2-standard-8"
phase4_vdi_gcp_node_disk_size_gb                     = 120
phase4_vdi_gcp_node_disk_type                        = "pd-balanced"
phase4_vdi_gcp_node_image_type                       = "COS_CONTAINERD"
phase4_vdi_gcp_node_spot                             = false
phase4_vdi_gcp_node_enable_autoscaling               = true
phase4_vdi_gcp_node_min_count                        = 1
phase4_vdi_gcp_node_max_count                        = 2
phase4_vdi_gcp_node_initial_count                    = 1
phase4_vdi_gcp_node_service_account                  = null
phase4_vdi_gcp_node_labels                           = {}
phase4_vdi_gcp_node_tags                             = []

# Optional standalone ops servers baseline.
phase4_enable_ops_stack = false

# Set at least one of public key or password before enabling phase4_enable_ops_stack.
phase4_ops_admin_username       = "opsadmin"
phase4_ops_admin_ssh_public_key = null
phase4_ops_admin_ssh_password   = null
phase4_ops_aws_key_pair_name    = null

# Additional trusted operator ranges for SSH access on top of all site CIDRs.
phase4_ops_trusted_ipv4_cidrs = []

# Public/UI ingress controls.
phase4_ops_openproject_http_allowed_ipv4_cidrs = null
phase4_ops_git_http_allowed_ipv4_cidrs         = null

# OpenProject (Site C / GCP)
phase4_ops_openproject_machine_type      = "e2-standard-4"
phase4_ops_openproject_boot_disk_size_gb = 80
phase4_ops_openproject_zone              = null
phase4_ops_openproject_image             = "openproject/openproject:17"
phase4_ops_openproject_host_name         = "openproject.local"

# Git server (Site B / AWS)
phase4_ops_git_instance_type       = "t3.small"
phase4_ops_git_root_volume_size_gb = 60
phase4_ops_git_image               = "docker.gitea.com/gitea:1.25.4"

# Ansible control node (Site A / AWS)
phase4_ops_ansible_instance_type       = "t3.small"
phase4_ops_ansible_root_volume_size_gb = 40

# Source-material Phase 5 deliverable tracking flags.
phase5_enable_resilience_validation = false
phase5_enable_backup_restore_drills = false
phase5_enable_handover_signoff      = false
