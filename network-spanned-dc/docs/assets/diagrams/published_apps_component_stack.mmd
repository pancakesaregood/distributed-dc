flowchart TD
  DNS["Public DNS (FQDN)"]
  EDGE["Edge Router Internet Interface"]
  FWRULE["Firewall DMZ Rule: HTTPS 443"]
  WAF["WAF Inspection"]
  LB["nginx Load Balancer"]
  APP["Backend Service"]
  DB["Database (optional)"]

  DNS --> EDGE
  EDGE --> FWRULE
  FWRULE --> WAF
  WAF --> LB
  LB --> APP
  APP -->|if required| DB
